{
  "$id": "https://pico.ai/schemas/identity/default",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neutrino Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            },
            "verification": {
              "via": "email"
            },
            "recovery": {
              "via": "email"
            }
          }
        },
        "username": {
          "type": "string",
          "minLength": 2
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["email"],
      "additionalProperties": true
    }
  },
  "required": ["traits"],
  "additionalProperties": false
}
