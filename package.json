{
  "name": "neutrino",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @neutrino/web",
    "dev:web": "npm run dev --workspace @neutrino/web",
    "dev:web:local": "npm run dev --workspace @neutrino/web -- -p 3001",
    "dev:api": "npm run dev --workspace @neutrino/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:core:postgres": "set -a; . ./.env; set +a; CORE_DATABASE_URL=\"$CORE_TEST_DATABASE_URL\" npm run migrate --workspace @neutrino/core && npm run test --workspace @neutrino/core -- src/repositories/postgres-core-repositories.test.ts",
    "secrets:prod:check": "bash scripts/check-production-secrets.sh",
    "deploy:api:prod": "bash scripts/deploy-production-api.sh",
    "verify:api:prod": "bash scripts/verify-production-api.sh",
    "db:local:ensure": "bash scripts/ensure-local-postgres-databases.sh",
    "kratos:local:render": "bash scripts/render-local-kratos-config.sh",
    "kratos:local:migrate": "bash scripts/migrate-local-kratos.sh",
    "kratos:local:start": "bash scripts/start-local-kratos.sh",
    "mailpit:local:start": "bash scripts/start-local-mailpit.sh",
    "phase2:drill": "bash scripts/phase2-core-persistence-drill.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "architecture:render": "node scripts/render-architecture-doc.mjs",
    "architecture:check": "node scripts/check-architecture-drift.mjs",
    "starter:version:bump": "node scripts/bump-pico-app-container-version.mjs",
    "starter:version:check": "node scripts/check-pico-app-container-version.mjs"
  },
  "overrides": {
    "@types/node": "$@types/node",
    "postcss": "$postcss",
    "brace-expansion": "$brace-expansion",
    "vite": "8.0.13"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "brace-expansion": "5.0.6",
    "postcss": "8.5.14"
  }
}
