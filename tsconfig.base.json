{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@neutrino/ai-gateway": [
        "packages/ai-gateway/src/index.ts"
      ],
      "@neutrino/core": [
        "packages/core/src/index.ts"
      ],
      "@neutrino/core/*": [
        "packages/core/src/*"
      ],
      "@neutrino/ports": [
        "packages/ports/src/index.ts"
      ],
      "@neutrino/ports/*": [
        "packages/ports/src/*"
      ],
      "@neutrino/schema": [
        "packages/schema/src/index.ts"
      ],
      "@neutrino/schema/*": [
        "packages/schema/src/*"
      ],
      "@neutrino/identity-gateway": [
        "packages/identity-gateway/src/index.ts"
      ],
      "@neutrino/platform-gateway": [
        "packages/platform-gateway/src/index.ts"
      ],
      "@neutrino/ui": [
        "packages/ui/src/index.ts"
      ],
      "@neutrino/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
