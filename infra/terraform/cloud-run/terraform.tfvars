project_id                    = "neutrino-491317"
region                        = "us-central1"
service_name                  = "neutrino-api"
container_image               = "us-central1-docker.pkg.dev/neutrino-491317/cloud-run-source-deploy/neutrino-api:bootstrap"
openai_api_key_secret_name    = "OPENAI_API_KEY"
api_proxy_secret_name         = "API_PROXY_SHARED_SECRET"
core_database_url_secret_name = "CORE_DATABASE_URL"
runtime_service_account_email = "695331385631-compute@developer.gserviceaccount.com"
allow_public_invoker          = false
invoker_iam_disabled          = true
enable_github_deploy_trigger  = true
github_owner                  = "pico-dot-ai"
github_repo                   = "neutrino"
github_deploy_branch_regex    = "^main$"
github_connection_name        = "neutrino-github"
github_repository_name        = "neutrino"
artifact_registry_hostname    = "us-central1-docker.pkg.dev"
artifact_registry_repository  = "cloud-run-source-deploy"
api_image_name                = "neutrino-api"
artifact_bucket_name          = "neutrino-artifacts-neutrino-491317"
object_storage_provider       = "gcs"
object_storage_gcs_prefix     = "artifacts"

enable_self_managed_postgres           = true
postgres_deployment_mode               = "hardened"
postgres_instance_name                 = "pico-postgres"
postgres_zone                          = "us-central1-a"
postgres_machine_type                  = "e2-small"
postgres_disk_size_gb                  = 20
postgres_network                       = "default"
postgres_app_database                  = "platform_prod"
postgres_app_user                      = "platform_user"
postgres_password_secret_name          = "POSTGRES_APP_PASSWORD"
postgres_container_image               = "pgvector/pgvector:pg17"
serverless_vpc_connector_name          = "pico-serverless"
serverless_vpc_connector_cidr          = "10.8.0.0/28"
serverless_vpc_connector_min_instances = 2
serverless_vpc_connector_max_instances = 3
postgres_public_allowed_cidrs          = []

enable_kratos                        = true
kratos_image                         = "oryd/kratos:v26.2.0"
kratos_public_service_name           = "neutrino-kratos-public"
kratos_admin_service_name            = "neutrino-kratos-admin"
kratos_migrate_job_name              = "neutrino-kratos-migrate"
kratos_db_bootstrap_job_name         = "neutrino-kratos-db-bootstrap"
kratos_public_ingress                = "INGRESS_TRAFFIC_ALL"
kratos_admin_ingress                 = "INGRESS_TRAFFIC_INTERNAL_ONLY"
kratos_log_level                     = "info"
kratos_revision_marker               = "2026-05-25h"
kratos_config_secret_name            = "KRATOS_CONFIG_YAML"
kratos_identity_schema_secret_name   = "KRATOS_IDENTITY_SCHEMA_JSON"
kratos_dsn_secret_name               = "KRATOS_DSN"
kratos_secrets_default_secret_name   = "KRATOS_SECRETS_DEFAULT"
kratos_secrets_cookie_secret_name    = "KRATOS_SECRETS_COOKIE"
kratos_oidc_providers_secret_name    = "KRATOS_OIDC_PROVIDERS_JSON"
kratos_postgres_password_secret_name = "KRATOS_POSTGRES_PASSWORD"
kratos_database_name                 = "kratos"
kratos_database_user                 = "kratos_user"
