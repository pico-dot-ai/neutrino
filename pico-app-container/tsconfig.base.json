{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@pico-app/schema": ["packages/schema/src/index.ts"],
      "@pico-app/schema/*": ["packages/schema/src/*"],
      "@pico-app/ports": ["packages/ports/src/index.ts"],
      "@pico-app/ports/*": ["packages/ports/src/*"]
    }
  }
}
